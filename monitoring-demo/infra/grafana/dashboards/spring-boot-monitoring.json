{
  "title": "Spring Boot Monitoring Demo",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requisicoes por segundo",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"monitoring-demo\"}[1m]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latencia HTTP p95",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"monitoring-demo\"}[1m])) by (le)) * 1000",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pedidos criados",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "demo_orders_created_total{application=\"monitoring-demo\"}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Falhas simuladas",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "demo_orders_failed_total{application=\"monitoring-demo\"}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Fila em processamento",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "demo_queue_size{application=\"monitoring-demo\"}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Taxa de erro 5xx",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",application=\"monitoring-demo\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"monitoring-demo\"}[1m]))",
          "legendFormat": "taxa 5xx"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Memoria heap usada",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_memory_used_bytes{area=\"heap\",application=\"monitoring-demo\"}",
          "legendFormat": "heap usada"
        }
      ]
    }
  ]
}